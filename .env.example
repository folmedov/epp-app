# Application configuration template
# Copy this file to .env and fill in the real values

APP_ENV=development
LOG_LEVEL=INFO

# ── Desarrollo local sin Docker ──────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/db_name

# ── Desarrollo local con Docker Compose ─────────────────────────────────────
# "postgres" es el nombre del servicio definido en docker-compose.yml.
# Docker Compose resuelve automáticamente ese nombre al contenedor correcto.
# DATABASE_URL=postgresql+asyncpg://eepp:eepp@postgres:5432/eepp

# ── Producción (Dokploy) ─────────────────────────────────────────────────────
# Usa las credenciales y el nombre de red interno que Dokploy asigna al
# servicio de base de datos. Configúralo en la UI de Dokploy, nunca en este archivo.
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@<dokploy-db-host>:5432/<db>
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/db_name

SCRAPER_TIMEOUT=30
SCRAPER_MAX_RETRIES=3